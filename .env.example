# Puerto publicado en el host
APP_PORT=8000

# Seguridad
# Si se deja vacío o con valor por defecto, deploy.sh generará un valor seguro automáticamente.
ADMIN_API_KEY=change-this-in-production
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Proxy reverso (Nginx Proxy Manager / Nginx / Traefik)
# Si publicas bajo dominio, agrega https://tu-dominio aquí (separado por comas).
# Ejemplo: ALLOWED_ORIGINS=https://indicadores.midominio.cl,http://localhost:8000
FORWARDED_ALLOW_IPS=*
PROXY_HEADERS=1
# Si la app vive bajo subruta (ej /indicadores), define ROOT_PATH=/indicadores
ROOT_PATH=

# ETL / World Bank
RUN_UPDATE_ON_STARTUP=1
WORLD_BANK_TIMEOUT_S=30
WORLD_BANK_MAX_RETRIES=3

# App
PORT=8000
